# ============================================
# VanalexCars Backend API - Configuration
# ============================================

# --- Serveur ---
PORT=4200
NODE_ENV=production
NEXT_PUBLIC_SERVER_URL=https://api.import-voiture-allemagne.fr

# --- Securite Payload ---
# Generer avec : openssl rand -base64 32
PAYLOAD_SECRET=CHANGE_THIS_SECRET

# --- Base de donnees MongoDB (Coolify) ---
DATABASE_URI=mongodb://root:PASSWORD@HOST:27017/?directConnection=true

# --- Frontend (CORS) ---
FRONTEND_URL=https://www.import-voiture-allemagne.fr

# --- GitHub API (optionnel) ---
# Augmente la limite de requetes de 60/h (anonyme) a 5000/h (avec token)
# Generer sur : https://github.com/settings/tokens (scope : public_repo)
# GITHUB_TOKEN=ghp_XXXXXXXXXXXXXXXXXXXX
