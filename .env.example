# ============================================
# VanalexCars Backend API - Configuration
# ============================================

# --- Serveur ---
PORT=4200
NODE_ENV=production
NEXT_PUBLIC_SERVER_URL=https://api.import-voiture-allemagne.fr

# --- Securite Payload ---
# Generer avec : openssl rand -base64 32
PAYLOAD_SECRET=CHANGE_THIS_SECRET

# --- Base de donnees MongoDB Atlas ---
DATABASE_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/?appName=cluster

# --- Frontend (CORS) ---
FRONTEND_URL=https://www.import-voiture-allemagne.fr
